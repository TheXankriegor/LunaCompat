<?xml version="1.0"?>
<ModuleDefinition xmlns:xsi='http://www.w3.org/2001/XMLSchema-instance' xsi:schemaLocation="luna:schema ../../PartSyncSchema.xsd">
	<Fields>
		<FieldDefinition>
			<FieldName>Enabled</FieldName>
		</FieldDefinition>
		<FieldDefinition>
			<FieldName>HibernateOnWarp</FieldName>
		</FieldDefinition>
		<FieldDefinition>
			<FieldName>Hibernating</FieldName>
		</FieldDefinition>
		<FieldDefinition>
			<FieldName>ManualControl</FieldName>
		</FieldDefinition>
		<FieldDefinition>
			<FieldName>CurrentReactorThrottle</FieldName>
			<MaxIntervalInMs>250</MaxIntervalInMs>
		</FieldDefinition>
		<FieldDefinition>
			<FieldName>CurrentThrottle</FieldName>
			<MaxIntervalInMs>250</MaxIntervalInMs>
		</FieldDefinition>
		<FieldDefinition>
			<FieldName>CurrentElectricalGeneration</FieldName>
			<MaxIntervalInMs>250</MaxIntervalInMs>
		</FieldDefinition>
		<FieldDefinition>
			<FieldName>MaxElectricalGeneration</FieldName>
			<MaxIntervalInMs>250</MaxIntervalInMs>
		</FieldDefinition>
		<FieldDefinition>
			<FieldName>InternalCoreTemperature</FieldName>
			<MaxIntervalInMs>1000</MaxIntervalInMs>
		</FieldDefinition>
		<FieldDefinition>
			<FieldName>InternalCoreTemperatureResponseScale</FieldName>
		</FieldDefinition>
		<FieldDefinition>
			<FieldName>CurrentSafetyOverride</FieldName>
		</FieldDefinition>
		<FieldDefinition>
			<FieldName>FirstLoad</FieldName>
		</FieldDefinition>
		<!-- LastUpdateTime is a per-physics-tick simulation clock: it changes every FixedUpdate,
		     so it can never be quieted by a throttle (it always fires at the interval ceiling) and
		     just floods the log/network. It is re-seeded on FirstLoad and still carried by LMP's
		     periodic full-protovessel sync for load-time catch-up, so it is intentionally not synced
		     as an incremental field. -->
		<FieldDefinition>
			<FieldName>CoreIntegrity</FieldName>
			<MaxIntervalInMs>1000</MaxIntervalInMs>
		</FieldDefinition>
	</Fields>
	<Methods>
		<MethodDefinition>
			<MethodName>EnableReactor</MethodName>
		</MethodDefinition>
		<MethodDefinition>
			<MethodName>DisableReactor</MethodName>
		</MethodDefinition>
		<MethodDefinition>
			<MethodName>EnableManual</MethodName>
		</MethodDefinition>
		<MethodDefinition>
			<MethodName>DisableManual</MethodName>
		</MethodDefinition>
		<MethodDefinition>
			<MethodName>EnableHibernate</MethodName>
		</MethodDefinition>
		<MethodDefinition>
			<MethodName>DisableHibernate</MethodName>
		</MethodDefinition>
		<MethodDefinition>
			<MethodName>RepairReactor</MethodName>
		</MethodDefinition>
	</Methods>
</ModuleDefinition>